{
  "name": "jira-release-notes-pdf",
  "version": "1.0.0",
  "description": "Fetch Jira release notes and generate a PDF changelog",
  "main": "server.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "nodemon server.js",
    "start": "node server.js",
    "dev:all": "concurrently \"npm run server\" \"npm run dev\"",
    "start:all": "npm run build && node server.js"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "lucide-react": "^1.7.0",
    "marked": "^17.0.5",
    "puppeteer": "^21.6.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "nodemon": "^3.0.2",
    "vite": "^8.0.3"
  }
}
